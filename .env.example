# ──────────────────────────────────────────────────────────────────────────────
# Tenant-Landlord web (Next.js) — environment template
# Copy to `.env.local` and fill in values. All vars are NEXT_PUBLIC_* and are
# inlined at BUILD time, so changing them on the host requires a rebuild/redeploy.
# Every var here is optional — the default shown applies when omitted.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Backend connection ─────────────────────────────────────────────────────────
# Base URL of the Express API. Use the deployed URL in production.
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
# WebSocket / Socket.IO endpoint (same Express server, no /api/v1 suffix).
NEXT_PUBLIC_WS_URL=http://localhost:3000

# ─── Brand (drives wordmark, copy, SEO, legal text, support emails, links) ────
NEXT_PUBLIC_BRAND_NAME=NaijaRental                 # Product name shown in UI
NEXT_PUBLIC_BRAND_DOMAIN=naijarental.com           # Domain; also used to build support emails
NEXT_PUBLIC_BRAND_LEGAL_NAME=NaijaRental Technologies Ltd  # Legal entity name (footer/legal)
NEXT_PUBLIC_BRAND_LOGO_URL=                         # Logo image URL/path (e.g. /brand/logo.svg). Empty → built-in icon mark
NEXT_PUBLIC_SITE_URL=https://naijarental.com       # Canonical site URL (SEO); defaults to https://<domain>

# ─── Mobile app download section (landing page) ──────────────────────────────
# Hidden by default since the apps aren't live. Set to true once iOS/Android ship.
NEXT_PUBLIC_SHOW_APP_DOWNLOAD=false
# Store URLs for the download badges (default "#" / no-op until the apps ship).
NEXT_PUBLIC_IOS_APP_URL=https://apps.apple.com/app/idXXXXXXXXX
NEXT_PUBLIC_ANDROID_APP_URL=https://play.google.com/store/apps/details?id=com.naijarental.app

# ─── Feature flags ────────────────────────────────────────────────────────────
# Refer & Earn for tenants. Defaults to locked ("coming soon"); set true to unlock.
NEXT_PUBLIC_REFER=false
